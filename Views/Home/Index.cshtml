@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">

    <div class="text-center">
        <h1>Hello World</h1>
        <p>B2C Test Application</p>
    </div>

    <hr />

    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <div class="text-center">

            <a href="/Account/Login" class="btn btn-primary">
                Login
            </a>

            <a href="/Account/SignUp" class="btn btn-success">
                Sign Up
            </a>

        </div>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-header">
                <h3>Welcome!</h3>
            </div>

            <div class="card-body">

                <p>
                    <strong>Name:</strong>
                    @(User.Claims.FirstOrDefault(c => c.Type == "name")?.Value
                        ?? "Not provided")
                </p>

                <p>
                    <strong>Policy:</strong>
                    @(User.Claims.FirstOrDefault(c => c.Type == "tfp")?.Value
                        ?? "Unknown")
                </p>

                <a href="/Account/Logout" class="btn btn-danger">
                    Logout
                </a>

            </div>
        </div>

        <div class="card">

            <div class="card-header">
                <h4>Claims</h4>
            </div>

            <div class="card-body">

                <table class="table table-striped table-bordered">

                    <thead>
                        <tr>
                            <th>Claim Type</th>
                            <th>Value</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var claim in User.Claims.OrderBy(c => c.Type))
                    {
                        <tr>
                            <td>
                                @Html.Raw(claim.Type)
                            </td>
                            <td>
                                @claim.Value
                            </td>
                        </tr>
                    }
                    </tbody>

                </table>

            </div>

        </div>
    }

</div>