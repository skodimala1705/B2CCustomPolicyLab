@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">

    <div class="savy-terminal">

        <div class="savy-header">
            <div class="savy-title">SAVY</div>
            <div class="savy-tagline">SURPASSING LIMIT</div>
        </div>

        <div class="savy-subtitle">
            IDENTITY ACCESS TERMINAL
        </div>

        @if (!(User.Identity?.IsAuthenticated ?? false))
        {
            <div class="savy-actions">
                <a href="/Account/Login" class="savy-btn savy-btn-primary">
                    LOGIN
                </a>

                <a href="/Account/SignUp" class="savy-btn savy-btn-secondary">
                    SIGN UP
                </a>
            </div>
        }

    </div>

    <hr />

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h3>Welcome!</h3>
            </div>

            <div class="card-body">

                <p>
                    <strong>Name:</strong>
                    @(User.Claims.FirstOrDefault(c => c.Type == "name")?.Value
                        ?? "Not provided")
                </p>

                <p>
                    <strong>Policy:</strong>
                    @(User.Claims.FirstOrDefault(c => c.Type == "tfp")?.Value
                        ?? "Unknown")
                </p>

                <a href="/Account/Logout" class="btn btn-danger">
                    Logout
                </a>

            </div>
        </div>

        <div class="card">

            <div class="card-header">
                <h4>Claims</h4>
            </div>

            <div class="card-body">

                <table class="table table-striped table-bordered">

                    <thead>
                        <tr>
                            <th>Claim Type</th>
                            <th>Value</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var claim in User.Claims.OrderBy(c => c.Type))
                        {
                            <tr>
                                <td>
                                    @Html.Raw(claim.Type)
                                </td>
                                <td>
                                    @claim.Value
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>
    }

</div>